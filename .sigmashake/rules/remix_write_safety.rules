# remix_write_safety.rules
# Technology: remix | Capability: write

rule remix-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_remix_PATTERN"
  MESSAGE "Blocked an unsafe pattern in remix. Use the recommended best practices for 2025/2026."
}

rule remix-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_remix_API"
  MESSAGE "You are using an outdated API for remix. Please upgrade to the newer API."
}
